#
# Chaves de API dos Provedores de IA
# Preencha pelo menos UMA das chaves abaixo
#

# DeepSeek (https://platform.deepseek.com) - recomendado, API muito barata
DEEPSEEK_API_KEY=

# Z.AI (https://z.ai) - modelos GLM, tem opcoes gratuitas (GLM-4.5 Flash)
# Copie a API KEY (nao o ID da chave!) em https://z.ai/manage-apikey/apikey-list
# Usa o endpoint do "GLM Coding Plan" - se sua conta for pay-as-you-go sem
# esse plano, pode ser necessario trocar o baseURL em src/agents/agent.ts
ZAI_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Google AI (https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=

# NVIDIA (https://build.nvidia.com/)
NVIDIA_API_KEY=

#
# Opcional
#

# Brave Search API (fallback quando DuckDuckGo falhar)
# Obtenha sua chave em: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=
