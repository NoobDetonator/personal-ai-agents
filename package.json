{
  "name": "personal-ai-agents",
  "version": "3.0.0",
  "description": "Personal AI agents with terminal and web interfaces.",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "clean": "rimraf dist",
    "check": "npm run lint && npm run check:web && npm run typecheck && npm test",
    "lint": "eslint src scripts web/login.js web/charts.js web/agent-icons.js web/sw.js && node scripts/lint-dashboard.mjs",
    "check:web": "node scripts/check-dashboard.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "eval:prompts": "npm run build && node scripts/prompt-eval.mjs",
    "db:reset": "rimraf data/agents.db"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "personal-assistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "duck-duck-scrape": "^2.2.7",
    "lucide": "1.24.0",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
